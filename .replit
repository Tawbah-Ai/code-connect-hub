modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 2; cd dashboard && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3001/tcp 2>/dev/null; sleep 2; cd backend && npm run dev"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "static"
build = ["npm", "--prefix", "dashboard", "run", "build"]
run = ["sh", "-c", "cd backend && npm install && npm run build && node dist/server.js"]
publicDir = "dashboard/dist"

[userenv]

[userenv.shared]
JWT_SECRET = "4a8aaaa9f55982144cdffd91b85e56bde99a3a424b7502bfb0b652aa0f725dd39a35681e1cdb0c0782f0e5eca7ac7d08"
