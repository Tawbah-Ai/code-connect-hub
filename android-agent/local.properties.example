## Android local.properties — copy this to local.properties (never commit local.properties)

## REQUIRED: The URL of your backend server (no trailing slash)
##
## On Replit (development):
##   The backend runs on port 3001, exposed externally on port 3000.
##   Open the Replit "Ports" panel and copy the URL next to port 3000.
##   It looks like: https://<repl-id>-00-<hash>-3000.picard.replit.dev
##
## On Replit (deployed/published):
##   Use your deployed backend URL, e.g.:
##   https://hybrid-control-backend.yourusername.replit.app
##
BACKEND_URL=https://YOUR-BACKEND-URL-HERE

## Android SDK path (auto-filled by Android Studio — do not set manually)
# sdk.dir=/Users/yourname/Library/Android/sdk
